[INFO] 2024-01-18 15:30:48,426 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 30, 48, 412933, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 5, 'team_name': 'team3', 'answer': b'# Check if Microsoft Defender Antivirus is enabled\r\n$defenderStatus = Get-MpPreference | Select-Object -ExpandProperty DisableRealtimeMonitoring\r\n\r\nif ($defenderStatus -eq $true) {\r\n    # Enable Microsoft Defender Antivirus\r\n    Set-MpPreference -DisableRealtimeMonitoring $false\r\n    Write-Host "Microsoft Defender Antivirus has been enabled for real-time protection."\r\n} else {\r\n    Write-Host "Microsoft Defender Antivirus is already enabled for real-time protection."\r\n}\r\n\r\n\r\n# Check if script is running with administrative privileges\r\nif (-not ([Security.Principal.WindowsPrincipal][Security.Principal.WindowsIdentity]::GetCurrent()).IsInRole([Security.Principal.WindowsBuiltInRole]::Administrator)) {\r\n    Write-Host "Please run this script as an administrator."\r\n    Exit\r\n}\r\n\r\n# Function to check if VSS is enabled\r\nfunction Is-VssEnabled {\r\n    $vssStatus = Get-Service -Name VSS | Select-Object -ExpandProperty Status\r\n    return $vssStatus -eq \'Running\'\r\n}\r\n\r\n# Function to check if there are existing VSS snapshots\r\nfunction Has-ExistingSnapshots {\r\n    $snapshots = Get-WmiObject -Query "Select * From Win32_ShadowCopy"\r\n    return $snapshots.Count -gt 0\r\n}\r\n\r\n# Function to create a new VSS snapshot\r\nfunction Create-VssSnapshot {\r\n    Write-Host "Creating a new Volume Shadow Copy Service (VSS) snapshot..."\r\n    $null = (Get-WmiObject -List Win32_ShadowCopy).Create("C:\\", "ClientAccessible")\r\n}\r\n\r\n# Main script logic\r\nif (Is-VssEnabled) {\r\n    if (Has-ExistingSnapshots) {\r\n        Write-Host "Existing Volume Shadow Copy Service (VSS) snapshots found."\r\n    } else {\r\n        Create-VssSnapshot\r\n        if (Has-ExistingSnapshots) {\r\n            Write-Host "A new Volume Shadow Copy Service (VSS) snapshot has been successfully created."\r\n        } else {\r\n            Write-Host "Failed to create a new Volume Shadow Copy Service (VSS) snapshot. Please check for errors."\r\n        }\r\n    }\r\n} else {\r\n    Write-Host "Volume Shadow Copy Service (VSS) is not enabled. Please enable VSS first."\r\n}\r\n'}
