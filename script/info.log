[INFO] 2024-01-18 14:22:40,579 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 6, 22, 40, 566168, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 3, 'team_name': 'team1', 'answer': b'# Check and enable Windows Defender or other antivirus software\n\n# Check if Windows Defender is enabled\n$defenderStatus = Get-MpPreference | Select-Object -ExpandProperty RealTimeProtectionEnabled\n\nif ($defenderStatus -eq $false) {\n    Write-Host "Windows Defender is currently disabled. Enabling..."\n    \n    # Enable Windows Defender\n    Set-MpPreference -RealTimeProtectionEnabled $true\n    \n    Write-Host "Windows Defender has been enabled for real-time protection."\n} else {\n    Write-Host "Windows Defender is already enabled for real-time protection."\n}\n\n# Check and enable Volume Shadow Copy Service (VSS)\n\n# Check if VSS is enabled\n$vssStatus = Get-Service -Name "vss" | Select-Object -ExpandProperty StartType\n\nif ($vssStatus -eq "Disabled") {\n    Write-Host "Volume Shadow Copy Service (VSS) is currently disabled. Enabling..."\n\n    # Enable VSS\n    Set-Service -Name "vss" -StartupType Automatic\n    Start-Service -Name "vss"\n\n    Write-Host "Volume Shadow Copy Service (VSS) has been enabled."\n} else {\n    Write-Host "Volume Shadow Copy Service (VSS) is already enabled."\n}'}
