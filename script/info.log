[INFO] 2024-01-18 17:36:34,526 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 36, 34, 518221, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Specify the username for krbtgt, DC, and tier 0 group member\n$krbtgtUsername = "krbtgt"\n$dcUsername = "Administrator" # Change this to the actual tier 0 group member username\n$tier0Username = "Tier0User"  # Change this to the actual tier 0 group member username\n\n# Generate strong random passwords\n$krbtgtPassword = Generate-StrongPassword\n$dcPassword = Generate-StrongPassword\n$tier0Password = Generate-StrongPassword\n\n# Change passwords for krbtgt, DC, and tier 0 group member\nSet-ADAccountPassword -Identity $krbtgtUsername -NewPassword $krbtgtPassword -Reset\nSet-ADAccountPassword -Identity $dcUsername -NewPassword $dcPassword -Reset\nSet-ADAccountPassword -Identity $tier0Username -NewPassword $tier0Password -Reset\n\n# Force replication to ensure changes are applied across the domain\nrepadmin /syncall /A /P\n\nWrite-Host "Passwords have been successfully changed for krbtgt, DC, and tier 0 group member."\n\n# Function to generate a strong random password\nfunction Generate-StrongPassword {\n    $length = 16 # Change the length as needed\n    $randomPassword = -join ((48..57) + (65..90) + (97..122) | Get-Random -Count $length | ForEach-Object { [char]$_ })\n    return $randomPassword | ConvertTo-SecureString -AsPlainText -Force\n}\n'}
