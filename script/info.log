[INFO] 2024-01-18 17:25:13,518 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 25, 13, 511624, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Function to enable Windows Defender or any antivirus software\nfunction EnableAntivirus {\n    $antivirusStatus = Get-MpPreference | Select-Object -ExpandProperty RealTimeMonitoringEnabled\n\n    if ($antivirusStatus -eq $false) {\n        Write-Host "Enabling antivirus software..."\n        Set-MpPreference -RealTimeMonitoringEnabled $true\n        Write-Host "Antivirus enabled successfully."\n    } else {\n        Write-Host "Antivirus is already enabled."\n    }\n}\n\n# Function to enable Volume Shadow Copy Service (VSS)\nfunction EnableVSS {\n    $vssStatus = Get-Service -Name vss | Select-Object -ExpandProperty Status\n\n    if ($vssStatus -ne \'Running\') {\n        Write-Host "Enabling Volume Shadow Copy Service (VSS)..."\n        Start-Service -Name vss\n        Set-Service -Name vss -StartupType Automatic\n        Write-Host "VSS enabled successfully."\n    } else {\n        Write-Host "VSS is already enabled and running."\n    }\n}\n\n# Check and enable antivirus\nEnableAntivirus\n\n# Check and enable VSS\nEnableVSS\n\n'}
