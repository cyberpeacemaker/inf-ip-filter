[INFO] 2024-01-18 17:42:19,569 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 42, 19, 561264, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 4, 'team_name': 'team2', 'answer': b'# \xe6\x94\xb9\xe9\x80\xb2\xe7\x9a\x84 PowerShell \xe8\x85\xb3\xe6\x9c\xac\xef\xbc\x8c\xe7\x94\xa8\xe6\x96\xbc\xe9\x87\x8d\xe8\xa8\xad\xe9\x97\x9c\xe9\x8d\xb5\xe5\xb8\xb3\xe6\x88\xb6\xe5\xaf\x86\xe7\xa2\xbc\n\n# \xe8\xbc\x89\xe5\x85\xa5 Active Directory \xe6\xa8\xa1\xe5\xa1\x8a\nImport-Module ActiveDirectory\n\n# \xe8\xa8\x98\xe9\x8c\x84\xe6\xaa\x94\xe6\xa1\x88\xe4\xbd\x8d\xe7\xbd\xae\n$logFile = "C:\\path\\to\\password-reset-log.txt"\n\n# \xe5\x87\xbd\xe6\x95\xb8\xef\xbc\x9a\xe8\xa8\x98\xe9\x8c\x84\xe6\xb6\x88\xe6\x81\xaf\nfunction Write-Log {\n    Param ([string]$message)\n    Add-Content -Path $logFile -Value "$(Get-Date) - $message"\n}\n\n# \xe5\x87\xbd\xe6\x95\xb8\xef\xbc\x9a\xe9\x87\x8d\xe8\xa8\xad krbtgt \xe5\xaf\x86\xe7\xa2\xbc\nfunction Reset-KrbtgtPassword {\n    try {\n        $krbtgt = Get-ADUser -Filter {SamAccountName -eq "krbtgt"} -ErrorAction Stop\n        for ($i = 0; $i -lt 2; $i++) {\n            $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n            Set-ADAccountPassword -Identity $krbtgt -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force) -ErrorAction Stop\n            Start-Sleep -Seconds 10 # \xe7\xad\x89\xe5\xbe\x85\xe8\xa4\x87\xe8\xa3\xbd\n            Write-Log "krbtgt \xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe6\x88\x90\xe5\x8a\x9f\xe3\x80\x82"\n        }\n    } catch {\n        Write-Log "\xe9\x8c\xaf\xe8\xaa\xa4\xef\xbc\x9a\xe7\x84\xa1\xe6\xb3\x95\xe9\x87\x8d\xe8\xa8\xad krbtgt \xe5\xaf\x86\xe7\xa2\xbc\xe3\x80\x82\xe9\x8c\xaf\xe8\xaa\xa4\xe8\xa9\xb3\xe6\x83\x85\xef\xbc\x9a$_"\n    }\n}\n\n# \xe5\x87\xbd\xe6\x95\xb8\xef\xbc\x9a\xe9\x87\x8d\xe8\xa8\xad\xe5\x9f\x9f\xe6\x8e\xa7\xe5\x88\xb6\xe5\x99\xa8\xe5\xaf\x86\xe7\xa2\xbc\nfunction Reset-DCPasswords {\n    try {\n        $dcs = Get-ADComputer -Filter {OperatingSystem -Like "*Server*"} -ErrorAction Stop\n        foreach ($dc in $dcs) {\n            $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n            Set-ADAccountPassword -Identity $dc -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force) -ErrorAction Stop\n            Write-Log "\xe5\x9f\x9f\xe6\x8e\xa7\xe5\x88\xb6\xe5\x99\xa8 $($dc.Name) \xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe6\x88\x90\xe5\x8a\x9f\xe3\x80\x82"\n        }\n    } catch {\n        Write-Log "\xe9\x8c\xaf\xe8\xaa\xa4\xef\xbc\x9a\xe7\x84\xa1\xe6\xb3\x95\xe9\x87\x8d\xe8\xa8\xad\xe5\x9f\x9f\xe6\x8e\xa7\xe5\x88\xb6\xe5\x99\xa8\xe5\xaf\x86\xe7\xa2\xbc\xe3\x80\x82\xe9\x8c\xaf\xe8\xaa\xa4\xe8\xa9\xb3\xe6\x83\x85\xef\xbc\x9a$_"\n    }\n}\n\n# \xe5\x87\xbd\xe6\x95\xb8\xef\xbc\x9a\xe9\x87\x8d\xe8\xa8\xad Tier 0 \xe7\xb5\x84\xe6\x88\x90\xe5\x93\xa1\xe5\xaf\x86\xe7\xa2\xbc\nfunction Reset-Tier0Passwords {\n    try {\n        $tier0GroupMembers = Get-ADGroupMember -Identity "Tier0Group" -ErrorAction Stop | Where-Object { $_.SamAccountName -ne "hcr" }\n        foreach ($member in $tier0GroupMembers) {\n            $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n            Set-ADAccountPassword -Identity $member -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force) -ErrorAction Stop\n            Write-Log "Tier 0 \xe7\xb5\x84\xe6\x88\x90\xe5\x93\xa1 $($member.Name) \xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe6\x88\x90\xe5\x8a\x9f\xe3\x80\x82"\n        }\n    } catch {\n        Write-Log "\xe9\x8c\xaf\xe8\xaa\xa4\xef\xbc\x9a\xe7\x84\xa1\xe6\xb3\x95\xe9\x87\x8d\xe8\xa8\xad Tier 0 \xe7\xb5\x84\xe6\x88\x90\xe5\x93\xa1\xe5\xaf\x86\xe7\xa2\xbc\xe3\x80\x82\xe9\x8c\xaf\xe8\xaa\xa4\xe8\xa9\xb3\xe6\x83\x85\xef\xbc\x9a$_"\n    }\n}\n\n# \xe5\x9f\xb7\xe8\xa1\x8c\xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe5\x87\xbd\xe6\x95\xb8\nWrite-Log "\xe9\x96\x8b\xe5\xa7\x8b\xe5\x9f\xb7\xe8\xa1\x8c\xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe6\xb5\x81\xe7\xa8\x8b\xe3\x80\x82"\nReset-KrbtgtPassword\nReset-DCPasswords\nReset-Tier0Passwords\nWrite-Log "\xe5\xaf\x86\xe7\xa2\xbc\xe9\x87\x8d\xe8\xa8\xad\xe6\xb5\x81\xe7\xa8\x8b\xe5\xae\x8c\xe6\x88\x90\xe3\x80\x82"\n'}
[INFO] 2024-01-18 17:42:19,742 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 42, 19, 734534, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 5, 'team_name': 'team3', 'answer': b'Function generateNewComplexPassword([int]$passwordNrChars) {\n    return -join ((33..126) | Get-Random -Count $passwordNrChars | % {[char]$_})\n}\n\n$krbtgtUsername = "krbtgt"\n$dcUsername = "HCR\\administrator"\n$tier0Username = "jimmy"\n\n$passwordNrChars = 64\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $krbtgtUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $krbtgtUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $dcUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $tier0Username -NewPassword $newPasswordSecure -Reset\n'}
[INFO] 2024-01-18 17:43:42,906 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 43, 42, 899281, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 5, 'team_name': 'team3', 'answer': b'# Iterate all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\n# Get the current user\'s name and construct the real backdoor path into "C:\\Users\\<UserName>\\AppData\\Local\\Temp\\"\n$userName = $env:USERNAME\n$realBackDoorPath = "C:\\Users\\" + $userName + "\\AppData\\Local\\Temp\\"\n\n# Iterate all schedule tasks\nforeach ($task in $scheduledTasks) {\n    foreach ($action in $task.Actions) {\n        # Get the real path of the action\n        $realPath = $ExecutionContext.SessionState.Path.GetUnresolvedProviderPathFromPSPath($action.Arguments)\n\n        # Check if realPath starts with realBackDoorPath, then it is a backdoor, delete the task\n        if ($realPath.StartsWith($realBackDoorPath, [System.StringComparison]::OrdinalIgnoreCase)) {\n            Write-Host "Scheduled Task: $($task.TaskName) is a potential backdoor. Removing..."\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n            Write-Host "Scheduled Task: $($task.TaskName) removed."\n        }\n    }\n}\n\nWrite-Host "Iteration completed."'}
[INFO] 2024-01-18 17:43:55,968 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 43, 55, 960797, tzinfo=<UTC>), 'action_id': 22, 'action_name': 'CVE-20XX-XXXXX', 'team_id': 4, 'team_name': 'team2', 'answer': b'alert http $EXTERNAL_NET any -> $HOME_NET any (msg:"Potential ManageEngine Desktop Central Java Deserialization Exploit"; flow:to_server,established; content:"POST"; http_method; content:"/mdm/client/v1/mdmLogUploader"; http_uri; content:"filename=logger.zip"; http_uri; content:"udid=si\\\\..\\\\..\\\\..\\\\webapps\\\\DesktopCentral\\\\_chart"; http_uri; content:"CommonsBeanutils1"; pcre:"/(serialVersionUID\\s*[\\x09-\\x0d\\x20]*[0-9]+[\\x09-\\x0d\\x20]*\\x63\\x66\\x8e\\x01\\x82\\xfe\\x4e\\xf1\\x7e|serialVersionUID[^;]*;\\s*private\\s*static\\s*final\\s*long\\s*serialVersionUID\\s*=\\s*0xcf8e0182fe4ef17e)/Ui"; sid:1000002; rev:2;)\n'}
