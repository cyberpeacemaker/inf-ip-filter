[INFO] 2024-01-18 17:38:36,533 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 38, 36, 526916, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Define the target folder\n$targetFolder = "$env:USERPROFILE\\AppData\\Local\\Temp\\"\n\n# Define the list of environment variables to check (case-insensitive)\n$environmentVariables = @(\'%APPDATA%\', \'%ProgramFiles%\', \'%Temp%\', \'%UserDomain%\', \'%UserName%\', \'%USERPROFILE%\', \'%WinDir%\')\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\n# Iterate through each scheduled task\nforeach ($task in $scheduledTasks) {\n    try {\n        # Get the actions of the task\n        $actions = $task.Actions\n\n        # Check each action for executables in the target folder or using specified environment variables\n        $removeTask = $false\n        foreach ($action in $actions) {\n            $executablePath = $action.Execute\n\n            # Resolve the actual executable path\n            $resolvedPath = (Resolve-Path -Path $executablePath).Path\n\n            # Check if the resolved path is in the target folder or uses specified environment variables\n            if ($resolvedPath -like "*$targetFolder*" -or $environmentVariables -contains $resolvedPath.ToUpper()) {\n                # If the resolved path is in the target folder or uses specified environment variables, set the flag to remove the task\n                $removeTask = $true\n                break\n            }\n        }\n\n        # Remove the task if the flag is set\n        if ($removeTask) {\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n            Write-Host "Scheduled task $($task.TaskName) removed. Executable: $($resolvedPath)"\n        }\n    } catch {\n        # Handle any errors, if needed\n        Write-Host "Error processing task $($task.TaskName): $_"\n    }\n}\n\nWrite-Host "Script execution completed."\n\n'}
[INFO] 2024-01-18 17:38:45,018 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 38, 45, 9245, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Define the path to check for backdoors\n$backdoorFolderPath = "$env:USERPROFILE\\AppData\\Local\\Temp"\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask | Where-Object { $_.Actions.Execute -like "*\\AppData\\Local\\Temp\\*" }\n\n# Loop through each task to check its execution path\nforeach ($task in $scheduledTasks) {\n    # Resolve environment variables in the task\'s execution path\n    $resolvedPath = [System.Environment]::ExpandEnvironmentVariables($task.Actions.Execute)\n\n    # Check if the resolved path starts with the backdoor folder path\n    if ($resolvedPath -like "$backdoorFolderPath\\*") {\n        # Unregister (delete) the scheduled task\n        Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n    }\n}\n\n# Stop and disable the Storage Sync Service\n$serviceName = "StorageSyncSvc"\nStop-Service -Name $serviceName -Force\nSet-Service -Name $serviceName -StartupType Disabled\n\n# Delete registry value data for the service (optional, needs admin rights)\n# Remove-ItemProperty -Path "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\$serviceName" -Name "Start" -Force\n'}
