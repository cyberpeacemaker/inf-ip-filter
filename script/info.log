[INFO] 2024-01-18 17:44:03,555 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 44, 3, 548791, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell script to remove specific scheduled tasks\n\n# Function to resolve environment variables in a path\nfunction Resolve-PathWithEnvironmentVariables {\n    param (\n        [string]$Path\n    )\n\n    # Replace environment variables with their values\n    return [System.Environment]::ExpandEnvironmentVariables($Path)\n}\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\nforeach ($task in $scheduledTasks) {\n    # Check each action in the task\n    foreach ($action in $task.Actions) {\n        try {\n            # Resolve environment variables in the action\'s Execute path\n            $resolvedPath = Resolve-PathWithEnvironmentVariables -Path $action.Execute\n\n            # Check if the action\'s execute path is in the specified directory\n            if ($resolvedPath -like "C:\\Users\\*\\AppData\\Local\\Temp\\*") {\n                # Unregister (delete) the task\n                Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n                Write-Host "Removed task: $($task.TaskName)"\n            }\n        } catch {\n            Write-Host "Error processing task: $($task.TaskName). Error: $_"\n        }\n    }\n}\n\nWrite-Host "Script completed."\n'}
