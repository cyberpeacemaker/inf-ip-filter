[INFO] 2024-01-18 16:23:03,546 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 23, 3, 531086, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# \xe6\xaa\xa2\xe6\x9f\xa5\xe4\xb8\xa6\xe5\x95\x9f\xe7\x94\xa8 Windows Defender \xe6\x88\x96\xe5\x85\xb6\xe4\xbb\x96\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\ntry {\n    $antivirusStatus = Get-MpPreference -ErrorAction Stop\n    if ($antivirusStatus.DisableRealtimeMonitoring -eq $true) {\n        Set-MpPreference -DisableRealtimeMonitoring $false\n        Write-Host "\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\xe5\xb7\xb2\xe5\x95\x9f\xe7\x94\xa8\xe3\x80\x82"\n    } else {\n        Write-Host "\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\xe5\xb7\xb2\xe8\x99\x95\xe6\x96\xbc\xe5\x95\x9f\xe7\x94\xa8\xe7\x8b\x80\xe6\x85\x8b\xe3\x80\x82"\n    }\n} catch {\n    Write-Host "\xe7\x84\xa1\xe6\xb3\x95\xe6\xaa\xa2\xe6\x9f\xa5\xe6\x88\x96\xe8\xa8\xad\xe5\xae\x9a Windows Defender \xe7\x8b\x80\xe6\x85\x8b\xe3\x80\x82"\n}\n\n# \xe6\xaa\xa2\xe6\x9f\xa5\xe4\xb8\xa6\xe5\x95\x9f\xe7\x94\xa8 VSS\ntry {\n    $vssService = Get-Service -Name "VSS" -ErrorAction Stop\n    if ($vssService.Status -ne "Running") {\n        Start-Service -Name "VSS"\n        Write-Host "VSS \xe6\x9c\x8d\xe5\x8b\x99\xe5\xb7\xb2\xe5\x95\x9f\xe5\x8b\x95\xe3\x80\x82"\n    } else {\n        Write-Host "VSS \xe6\x9c\x8d\xe5\x8b\x99\xe5\xb7\xb2\xe5\x9c\xa8\xe9\x81\x8b\xe8\xa1\x8c\xe4\xb8\xad\xe3\x80\x82"\n    }\n\n    $vssSnapshots = Get-WmiObject -Class Win32_ShadowCopy\n    if ($vssSnapshots) {\n        Write-Host "VSS \xe5\xbf\xab\xe7\x85\xa7\xe6\x95\xb8\xe9\x87\x8f\xef\xbc\x9a" $vssSnapshots.Count\n    } else {\n        Write-Host "VSS \xe5\x95\x9f\xe7\x94\xa8\xef\xbc\x8c\xe4\xbd\x86\xe6\x9c\xaa\xe6\x89\xbe\xe5\x88\xb0\xe5\xbf\xab\xe7\x85\xa7\xe3\x80\x82"\n    }\n} catch {\n    Write-Host "\xe7\x84\xa1\xe6\xb3\x95\xe6\xaa\xa2\xe6\x9f\xa5 VSS \xe6\x9c\x8d\xe5\x8b\x99\xe6\x88\x96\xe5\xbf\xab\xe7\x85\xa7\xe3\x80\x82"\n}\n'}
