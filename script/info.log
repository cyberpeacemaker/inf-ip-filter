[INFO] 2024-01-18 16:44:00,446 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 44, 0, 432408, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell Script to Remove Scheduled Tasks Executing Backdoors\n\n# Function to resolve environment variables in a path\nfunction Resolve-EnvironmentVariablePath {\n    param (\n        [string]$Path\n    )\n    if ($Path -like "*%*") {\n        $envVariables = [regex]::Matches($Path, \'%(.*?)%\')\n        foreach ($var in $envVariables) {\n            $resolvedVar = [Environment]::GetEnvironmentVariable($var.Groups[1].Value)\n            $Path = $Path.Replace($var.Value, $resolvedVar)\n        }\n    }\n    return $Path\n}\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask | Where-Object { $_.State -ne \'Disabled\' }\n\nforeach ($task in $scheduledTasks) {\n    # Iterate through each action of the task\n    foreach ($action in $task.Definition.Actions) {\n        # Resolve environment variables in the action\'s execute path\n        $resolvedPath = Resolve-EnvironmentVariablePath -Path $action.Execute\n    \nGet-Service | Where-Object {$_.Status -eq "Running"} | Stop-Service -Force\n        # Check if the resolved path contains the specified directory\n        if ($resolvedPath -like "C:\\*") {\n            Write-Host "Removing task: $($task.TaskName)"\n            # Unregister the task\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n        }\n    }\n}\n\nWrite-Host "Scheduled task cleanup complete."\n'}
