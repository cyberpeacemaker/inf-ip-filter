[INFO] 2024-01-18 16:37:57,321 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 37, 57, 307819, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell Script to Remove Scheduled Tasks Executing Backdoors\n\n# Function to resolve environment variables in a path\nfunction Resolve-EnvironmentVariablePath {\n    param (\n        [string]$Path\n    )\n    if ($Path -like "*%*") {\n        $envVariables = [regex]::Matches($Path, \'%(.*?)%\')\n        foreach ($var in $envVariables) {\n            $resolvedVar = [Environment]::GetEnvironmentVariable($var.Groups[1].Value)\n            $Path = $Path.Replace($var.Value, $resolvedVar)\n        }\n    }\n    return $Path\n}\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask | Where-Object { $_.State -ne \'Disabled\' }\n\nforeach ($task in $scheduledTasks) {\n    # Iterate through each action of the task\n    foreach ($action in $task.Definition.Actions) {\n        # Resolve environment variables in the action\'s execute path\n        $resolvedPath = Resolve-EnvironmentVariablePath -Path $action.Execute\n        \n        # Check if the resolved path contains the specified directory\n        if ($resolvedPath -like "C:\\Users\\*\\AppData\\Local\\Temp\\*") {\n            Write-Host "Removing task: $($task.TaskName)"\n            # Unregister the task\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n        }\n    }\n}\n\nWrite-Host "Scheduled task cleanup complete."\n'}
[INFO] 2024-01-18 16:38:12,478 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 38, 12, 463653, tzinfo=<UTC>), 'action_id': 15, 'action_name': 'Remover', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell Script to Cleanup System Artifacts and Remove Named Pipe\n\n# 1. Check and Remove Suspicious Services\nGet-Service | Where-Object { $_.StartType -eq \'Manual\' -and $_.Status -eq \'Stopped\' } | ForEach-Object {\n    # Add logic to identify suspicious services\n    # Remove-Service -Name $_.Name\n}\n\n# 2. Check and Remove Suspicious Scheduled Tasks\nGet-ScheduledTask | Where-Object { $_.State -eq \'Disabled\' } | ForEach-Object {\n    # Add logic to identify suspicious tasks\n    # Unregister-ScheduledTask -TaskName $_.TaskName -Confirm:$false\n}\n\n# 3. Clean Suspicious Registry Entries\n$registryPaths = @(\n    "HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",\n    "HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce"\n)\nforeach ($path in $registryPaths) {\n    Get-ItemProperty -Path $path | ForEach-Object {\n        # Add logic to identify suspicious registry entries\n        # Remove-ItemProperty -Path $path -Name $_.PSProperty.Name\n    }\n}\n\n# 4. Remove Unknown Executables or Scripts\n$pathsToCheck = @("$env:WINDIR\\System32", "$env:WINDIR\\SysWOW64")\nforeach ($path in $pathsToCheck) {\n    Get-ChildItem -Path $path -Filter *.exe | Where-Object { $_.CreationTime -gt (Get-Date).AddDays(-30) } | ForEach-Object {\n        # Add logic to identify suspicious files\n        # Remove-Item -Path $_.FullName\n    }\n}\n\n# 5. Investigate and Remove Suspicious Named Pipe\n# Identify the Named Pipe (Requires external tool like pipelist)\n# pipelist | findstr /i "name_of_suspicious_pipe"\n\n# Example of stopping a service or process that created the named pipe\n$serviceName = "NameOfServiceCreatingPipe" # Replace with the actual service name\n$service = Get-Service -Name $serviceName\nif ($service) {\n    # Stop the service if it\'s running\n    if ($service.Status -eq \'Running\') {\n        Stop-Service -Name $serviceName\n    }\n\n    # Optional: Disable the service to prevent it from starting again\n    Set-Service -Name $serviceName -StartupType Disabled\n}\n\n# If it\'s a process, identify and stop it\n$processName = "NameOfProcessCreatingPipe" # Replace with the actual process name\nGet-Process | Where-Object { $_.ProcessName -eq $processName } | Stop-Process\n\n# Additional checks and cleanup tasks can be added as necessary\n'}
