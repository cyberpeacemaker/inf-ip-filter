[INFO] 2024-01-18 17:54:51,495 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 54, 51, 487702, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 4, 'team_name': 'team2', 'answer': b"# Import the Active Directory module\nImport-Module ActiveDirectory\n\n$plainTextPassword = 'asoufgskudgfksdgfksgbfksdbfks'\n$securePassword = ConvertTo-SecureString -String $plainTextPassword -AsPlainText -Force\n# Specify the krbtgt account\n$acc = Get-ADUser -Identity krbtgt\nSet-ADAccountPassword -Identity $acc -Reset -NewPassword $securePassword\n\n$acc = Get-ADUser -Identity administrator\nSet-ADAccountPassword -Identity $acc -Reset -NewPassword $securePassword\n\n$acc = Get-ADUser -Identity jimmy\nSet-ADAccountPassword -Identity $acc -Reset -NewPassword $securePassword\n"}
[INFO] 2024-01-18 17:55:17,394 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 55, 17, 386932, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Set the path of the backdoor\n$backdoorPath = "C:\\Users\\*\\AppData\\Local\\Temp\\backdoor.exe"\n\n# Get all user profiles on the system\n$userProfiles = Get-WmiObject Win32_UserProfile | Where-Object { $_.Special -eq $false }\n\n# Iterate through each user profile and check for scheduled tasks related to the backdoor\nforeach ($profile in $userProfiles) {\n    $username = $profile.LocalPath.Split(\'\\\')[-1]\n    $userBackdoorPath = $backdoorPath -replace \'\\*\', $username\n\n    # Get all scheduled tasks for the current user\n    $scheduledTasks = Get-ScheduledTask -User $username\n\n    # Iterate through each task and check if it points to the backdoor path\n    foreach ($task in $scheduledTasks) {\n        $actions = $task.Actions\n        foreach ($action in $actions) {\n            $arguments = $action.Arguments -replace \'%APPDATA%\', $env:APPDATA -replace \'%ProgramFiles%\', $env:ProgramFiles -replace \'%Temp%\', $env:TEMP -replace \'%UserDomain%\', $env:USERDOMAIN -replace \'%UserName%\', $env:USERNAME -replace \'%USERPROFILE%\', $env:USERPROFILE -replace \'%WinDir%\', $env:WINDIR\n            if ($arguments -ilike "*$userBackdoorPath*") {\n                # Delete the scheduled task\n                Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n                Write-Host "Deleted task \'$($task.TaskName)\' for user \'$username\'"\n            }\n        }\n    }\n}\n\nWrite-Host "Script execution completed."\n'}
