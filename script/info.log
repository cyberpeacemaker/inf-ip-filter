[INFO] 2024-01-18 15:30:29,602 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 30, 29, 587173, tzinfo=<UTC>), 'action_id': 19, 'action_name': 'Firewall: Network Segments', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Generated by iptables-save v1.8.8 (nf_tables) on Thu Jan 18 01:33:30 2024\n*filter\n:INPUT DROP [0:0]\n:FORWARD DROP [0:0]\n:OUTPUT ACCEPT [0:0]\n:DOCKER - [0:0]\n:DOCKER-ISOLATION-STAGE-1 - [0:0]\n:DOCKER-ISOLATION-STAGE-2 - [0:0]\n:DOCKER-USER - [0:0]\n-A INPUT -i lo -j ACCEPT\n-A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\n-A INPUT -p tcp -m tcp --dport 22 -j ACCEPT\n-A FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\n-A FORWARD -p tcp -m tcp --dport 22 -j ACCEPT\n-A FORWARD -s 192.68.0.50/32 -p tcp -m multiport --sports 22,443 -j ACCEPT\n-A FORWARD -s 192.68.0.25/32 -p tcp -m multiport --sports 110,443,995,3389 -j ACCEPT\n-A FORWARD -d 192.68.1.100/32 -p tcp -m multiport --dports 389,445,636,3389,80 -j ACCEPT\n-A FORWARD -s 192.68.0.50/32 -d 192.68.1.0/24 -j DROP\n-A FORWARD -s 192.68.0.25/32 -d 192.68.1.0/24 -j DROP\n-A FORWARD -s 192.68.0.0/24 -d 192.68.1.100/32 -p tcp -m tcp --dport 80 -j DROP\n-A FORWARD -s 192.68.1.0/24 -d 192.68.0.0/24 -p tcp -m tcp --dport 22 -j DROP\n-A FORWARD -s 192.68.1.100/32 -d 192.68.0.50/32 -p tcp -m tcp --dport 443 -j ACCEPT\n-A OUTPUT -o lo -j ACCEPT\n-A OUTPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\nCOMMIT\n# Complete on Thu Jan 18 01:33:30 2024'}
