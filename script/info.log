[INFO] 2024-01-18 15:08:02,593 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 8, 2, 578741, tzinfo=<UTC>), 'action_id': 18, 'action_name': 'YARA Rule for Miner', 'team_id': 4, 'team_name': 'team2', 'answer': b'rule Detect_XMR_Stak_Rx_Process {\n    meta:\n        description = "YARA rule to detect xmr-stak-rx.exe process"\n        author = "Your Name"\n        date = "2024-01-18"\n    condition:\n        // Check if the process name is xmr-stak-rx.exe\n        uint16(0) == 0x786D and // \'xm\' in ASCII\n        uint16(2) == 0x722D and // \'r-\' in ASCII\n        uint16(4) == 0x7374 and // \'st\' in ASCII\n        uint16(6) == 0x616B and // \'ak\' in ASCII\n        uint16(8) == 0x2D72 and // \'-rx\' in ASCII\n        uint16(10) == 0x782E  // \'.exe\' in ASCII\n}\n'}
