[INFO] 2024-01-18 15:56:33,628 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 56, 33, 615105, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Check and Enable Windows Defender or Antivirus\nTry {\n    # Attempt to get the status of Windows Defender\n    $defenderStatus = Get-MpPreference -ErrorAction Stop\n\n    # Check if Real-Time Protection is disabled\n    if (-not $defenderStatus.DisableRealtimeMonitoring) {\n        Write-Host "Windows Defender Real-Time Protection is enabled."\n    } else {\n        # Enabling Windows Defender Real-Time Protection\n        Set-MpPreference -DisableRealtimeMonitoring $false\n        Write-Host "Windows Defender Real-Time Protection has been enabled."\n    }\n} Catch {\n    Write-Host "Error: Unable to check or enable Windows Defender. It may be managed by another antivirus software or group policy."\n}\n\n# Check and Enable Volume Shadow Copy Service\nTry {\n    # Get the current status of the VSS service\n    $vssService = Get-Service -Name "VSS" -ErrorAction Stop\n\n    # Check if VSS is running\n    if ($vssService.Status -eq \'Running\') {\n        Write-Host "Volume Shadow Copy Service is already running."\n    } else {\n        # Start the VSS service\n        Start-Service -Name "VSS"\n        Write-Host "Volume Shadow Copy Service has been started."\n    }\n} Catch {\n    Write-Host "Error: Unable to check or start Volume Shadow Copy Service."\n}\n'}
[INFO] 2024-01-18 15:56:39,967 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 56, 39, 953645, tzinfo=<UTC>), 'action_id': 18, 'action_name': 'YARA Rule for Miner', 'team_id': 5, 'team_name': 'team3', 'answer': b'rule upx {\n    meta:\n        description = "UPX packed file"\n\n    strings:\n        $mz = "MZ"\n        $upx1 = {55505830000000}\n        $upx2 = {55505831000000}\n        $upx_sig = "UPX!"\n\n    condition:\n        $mz at 0 and $upx1 in (0..1024) and $upx2 in (0..1024) and $upx_sig in (0..1024)\n}\n\nrule XMRig {\n    meta:\n        description = "XMRig"\n\n    strings:\n        // $xmrig_amd_bfe = "xmrig_amd_bfe"\n        // $XMRig_version = /XMRig \\d.\\d.\\d/\n        $xmrig = "XMRig"\n        $xmrig_cuda = "xmrig_cuda"\n\n    condition:\n        not $xmrig_cuda and any of them\n}\n\n\n'}
