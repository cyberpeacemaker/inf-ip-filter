[INFO] 2024-01-18 17:15:32,003 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 15, 31, 995678, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Define variables\n$serviceName = "Storage Sync Service"\n$processName = "lsass.exe"\n$registryPath = "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\StorSyncSvc"\n$registryValueName = "YourValueName" # Replace with the actual value name\n$defaultRegistryValueData = "YourDefaultValue" # Replace with the default or safe value data\n\n# Remove specific scheduled tasks\n$scheduledTasks = Get-ScheduledTask\nforeach ($task in $scheduledTasks) {\n    $actions = $task.Actions.Execute\n    foreach ($action in $actions) {\n        if ($action -like "*\\AppData\\Local\\Temp\\*" -or $action -like "C:\\Windows\\TEMP\\*") {\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n            Write-Host "Removed scheduled task: $($task.TaskName)"\n        }\n    }\n}\nWrite-Host "Backdoor related scheduled tasks have been removed."\n\n# Stop and remove the service\nif (Get-Service -Name $serviceName -ErrorAction SilentlyContinue) {\n    Stop-Service -Name $serviceName -Force -ErrorAction SilentlyContinue\n    Remove-Service -Name $serviceName -ErrorAction SilentlyContinue\n    Write-Host "Service \'$serviceName\' has been stopped and removed."\n} else {\n    Write-Host "Service \'$serviceName\' not found."\n}\n\n# Terminate the associated process\n$process = Get-Process -Name $processName -ErrorAction SilentlyContinue\nif ($process) {\n    Stop-Process -Name $processName -Force\n    Write-Host "Process \'$processName\' has been terminated."\n} else {\n    Write-Host "Process \'$processName\' not found."\n}\n\n# Reset the registry value\nif (Test-Path $registryPath) {\n    Set-ItemProperty -Path $registryPath -Name $registryValueName -Value $defaultRegistryValueData\n    Write-Host "Registry value \'$registryValueName\' in \'$registryPath\' has been reset to its default state."\n} else {\n    Write-Host "Registry path \'$registryPath\' not found."\n}\n'}
