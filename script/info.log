[INFO] 2024-01-18 16:34:02,360 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 34, 2, 346576, tzinfo=<UTC>), 'action_id': 22, 'action_name': 'CVE-20XX-XXXXX', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Enhanced Rule for CVE-2020-10189 (Exploit Attempts)\nalert tcp any any -> $HOME_NET any (msg:"Potential CVE-2020-10189 Exploit Attempt - Enhanced"; flow:established,to_server; content:"/DesktopCentral/"; http_uri; pcre:"/(\\.|%2E|%252E)(\\.|%2E|%252E)*/Ui"; pcre:"/logger(\\.|%2E|%252E)zip/Ui"; dsize:<400; classtype:web-application-attack; sid:1000101; rev:1;)\n\n# Generalized Rule for Detecting Directory Traversal Attempts\nalert tcp any any -> $HOME_NET any (msg:"Potential Directory Traversal Attack"; flow:established,to_server; pcre:"/(\\.\\.\\/|(\\%2E){2}\\/|(\\%252E){2}\\/)+/Ui"; http_uri; classtype:web-application-attack; sid:1000102; rev:1;)\n\n# Rule for Unusually Long or Encoded URLs\nalert tcp any any -> $HOME_NET any (msg:"Suspiciously Long or Encoded URL Detected"; flow:established,to_server; http_uri; urilen:>500; content:"%"; http_uri; classtype:web-application-attack; sid:1000103; rev:1;)\n'}
