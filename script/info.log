[INFO] 2024-01-18 16:30:27,160 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 30, 27, 147189, tzinfo=<UTC>), 'action_id': 15, 'action_name': 'Remover', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell Script to Cleanup System Artifacts\n\n# 1. Check and Remove Suspicious Services\nGet-Service | Where-Object { $_.StartType -eq \'Manual\' -and $_.Status -eq \'Stopped\' } | ForEach-Object {\n    # Add logic to identify suspicious services\n    # Remove-Service -Name $_.Name\n}\n\n# 2. Check and Remove Suspicious Scheduled Tasks\nGet-ScheduledTask | Where-Object { $_.State -eq \'Disabled\' } | ForEach-Object {\n    # Add logic to identify suspicious tasks\n    # Unregister-ScheduledTask -TaskName $_.TaskName -Confirm:$false\n}\n\n# 3. Investigate and Remove Suspicious Named Pipes\n# This is more complex as PowerShell doesn\'t have a native way to list named pipes.\n# You might need additional tools or scripts to identify and remove suspicious named pipes.\n\n# 4. Clean Suspicious Registry Entries\n# Define known locations such as Run, RunOnce\n$registryPaths = @(\n    "HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\Run",\n    "HKLM:\\Software\\Microsoft\\Windows\\CurrentVersion\\RunOnce"\n)\nforeach ($path in $registryPaths) {\n    Get-ItemProperty -Path $path | ForEach-Object {\n        # Add logic to identify suspicious registry entries\n        # Remove-ItemProperty -Path $path -Name $_.PSProperty.Name\n    }\n}\n\n# 5. Remove Unknown Executables or Scripts\n$pathsToCheck = @("$env:WINDIR\\System32", "$env:WINDIR\\SysWOW64")\nforeach ($path in $pathsToCheck) {\n    Get-ChildItem -Path $path -Filter *.exe | Where-Object { $_.CreationTime -gt (Get-Date).AddDays(-30) } | ForEach-Object {\n        # Add logic to identify suspicious files\n        # Remove-Item -Path $_.FullName\n    }\n}\n\n# Additional checks and cleanup tasks can be added as necessary:qw:wq\n'}
[INFO] 2024-01-18 16:32:05,867 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 32, 5, 853542, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# \xe6\xaa\xa2\xe6\x9f\xa5\xe4\xb8\xa6\xe5\x95\x9f\xe7\x94\xa8 Windows Defender \xe6\x88\x96\xe5\x85\xb6\xe4\xbb\x96\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\ntry {\n    $antivirusStatus = Get-MpPreference -ErrorAction Stop\n    if ($antivirusStatus.DisableRealtimeMonitoring -eq $true) {\n        Set-MpPreference -DisableRealtimeMonitoring $false\n        Write-Host "\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\xe5\xb7\xb2\xe5\x95\x9f\xe7\x94\xa8\xe3\x80\x82"\n    } else {\n        Write-Host "\xe9\x98\xb2\xe6\xaf\x92\xe8\xbb\x9f\xe9\xab\x94\xe5\xb7\xb2\xe8\x99\x95\xe6\x96\xbc\xe5\x95\x9f\xe7\x94\xa8\xe7\x8b\x80\xe6\x85\x8b\xe3\x80\x82"\n    }\n} catch {\n    Write-Host "\xe7\x84\xa1\xe6\xb3\x95\xe6\xaa\xa2\xe6\x9f\xa5\xe6\x88\x96\xe8\xa8\xad\xe5\xae\x9a Windows Defender \xe7\x8b\x80\xe6\x85\x8b\xe3\x80\x82"\n}\n\n\n# \xe6\xaa\xa2\xe6\x9f\xa5 VSS \xe6\x9c\x8d\xe5\x8b\x99\xe4\xb8\xa6\xe5\x9f\xb7\xe8\xa1\x8c\xe5\xbf\xab\xe7\x85\xa7\ntry {\n    # \xe6\xaa\xa2\xe6\x9f\xa5 VSS \xe6\x9c\x8d\xe5\x8b\x99\xe7\x8b\x80\xe6\x85\x8b\n    $vssService = Get-Service -Name "VSS"\n    if ($vssService.Status -ne "Running") {\n        # \xe5\x95\x9f\xe5\x8b\x95 VSS \xe6\x9c\x8d\xe5\x8b\x99\n        Start-Service -Name "VSS"\n        Write-Host "VSS \xe6\x9c\x8d\xe5\x8b\x99\xe5\xb7\xb2\xe5\x95\x9f\xe5\x8b\x95\xe3\x80\x82"\n    }\n\n    # \xe6\xaa\xa2\xe6\x9f\xa5\xe6\x98\xaf\xe5\x90\xa6\xe5\xb7\xb2\xe6\x9c\x89\xe5\xbf\xab\xe7\x85\xa7\n    $snapshots = Get-WmiObject -Class Win32_ShadowCopy\n    if ($snapshots -eq $null) {\n        # \xe5\x89\xb5\xe5\xbb\xba\xe6\x96\xb0\xe7\x9a\x84\xe5\xbf\xab\xe7\x85\xa7\n        $vssAdmin = "vssadmin.exe Create Shadow /For=C:"\n        Invoke-Expression $vssAdmin\n        Write-Host "\xe5\xb7\xb2\xe5\x89\xb5\xe5\xbb\xba\xe6\x96\xb0\xe7\x9a\x84 VSS \xe5\xbf\xab\xe7\x85\xa7\xe3\x80\x82"\n    } else {\n        Write-Host "\xe5\xb7\xb2\xe5\xad\x98\xe5\x9c\xa8 VSS \xe5\xbf\xab\xe7\x85\xa7\xe3\x80\x82"\n    }\n} catch {\n    Write-Host "\xe7\x84\xa1\xe6\xb3\x95\xe6\xaa\xa2\xe6\x9f\xa5\xe6\x88\x96\xe4\xbf\xae\xe6\x94\xb9 VSS \xe6\x9c\x8d\xe5\x8b\x99\xe5\x8f\x8a\xe5\xbf\xab\xe7\x85\xa7\xe7\x8b\x80\xe6\x85\x8b\xe3\x80\x82"\n}\n\n'}
