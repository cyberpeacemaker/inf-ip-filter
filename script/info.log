[INFO] 2024-01-18 17:20:31,240 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 20, 31, 233584, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Import the Active Directory module\nImport-Module ActiveDirectory\n\n# Specify the krbtgt account\n$krbtgtAccount = Get-ADUser -Identity krbtgt\n\n# Reset the krbtgt password\nSet-ADAccountPassword -Identity $krbtgtAccount -Reset\n\n# Force replication to other domain controllers\nRepadmin /syncall /A /P\n\n# Optional: Check the replication status\nRepadmin /showrepl\n'}
[INFO] 2024-01-18 17:20:38,340 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 20, 38, 333879, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Function to resolve environment variables in a path\nfunction Resolve-PathWithEnvironmentVariable {\n    param (\n        [string]$Path\n    )\n    if ($Path -like "*%*") {\n        $regex = [regex]::new(\'%([^%]+)%\')\n        $matches = $regex.Matches($Path)\n        foreach ($match in $matches) {\n            $envVar = $match.Groups[1].Value\n            $envValue = [System.Environment]::GetEnvironmentVariable($envVar)\n            $Path = $Path.Replace("%$envVar%", $envValue)\n        }\n    }\n    return $Path\n}\n\n# Delete Scheduled Tasks that execute backdoor from a specific folder\n$backdoorFolderPath = "C:\\Users\\$env:USERNAME\\AppData\\Local\\Temp"\nGet-ScheduledTask | ForEach-Object {\n    try {\n        $taskPath = Resolve-PathWithEnvironmentVariable -Path $_.Actions.Execute\n        if ($taskPath -like "$backdoorFolderPath\\*") {\n            Unregister-ScheduledTask -TaskName $_.TaskName -Confirm:$false\n            Write-Host "Deleted task: $($_.TaskName)"\n        }\n    } catch {\n        Write-Warning "Error processing task: $($_.TaskName)"\n    }\n}\n\n# Stop the "Storage Sync Service"\n$serviceName = "Storage Sync Service"\ntry {\n    Stop-Service -Name $serviceName -Force\n    Write-Host "Service \'$serviceName\' stopped successfully."\n} catch {\n    Write-Warning "Failed to stop service \'$serviceName\'. Error: $_"\n}\n\n# Delete Registry Value Data\n$registryPath = "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\Storage Sync Service"\n$registryValue = "C:\\Windows\\TEMP\\aTxm.exe xkMvljVS"\ntry {\n    Remove-ItemProperty -Path $registryPath -Name "ImagePath" -Value $registryValue\n    Write-Host "Registry value removed successfully."\n} catch {\n    Write-Warning "Failed to remove registry value. Error: $_"\n}\n'}
