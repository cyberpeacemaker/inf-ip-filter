[INFO] 2024-01-18 17:02:44,081 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 2, 44, 74557, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Define the target folder\n$targetFolder = "$env:USERPROFILE\\AppData\\Local\\Temp\\"\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\n# Iterate through each scheduled task\nforeach ($task in $scheduledTasks) {\n    try {\n        # Get the actions of the task\n        $actions = $task.Actions\n\n        # Check each action for executables in the target folder\n        foreach ($action in $actions) {\n            $executablePath = $action.Execute\n            if ($executablePath -like "*$targetFolder*") {\n                # If the executable is in the target folder, remove the task\n                Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n                Write-Host "Scheduled task $($task.TaskName) removed. Executable: $($executablePath)"\n                break  # No need to check other actions for this task\n            }\n        }\n    } catch {\n        # Handle any errors, if needed\n        Write-Host "Error processing task $($task.TaskName): $_"\n    }\n}\n\nWrite-Host "Script execution completed."\n\n'}
[INFO] 2024-01-18 17:03:09,003 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 3, 8, 996125, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'Set-MpPreference -DisableRealtimeMonitoring $false\nStart-Service -Name VSS\n$command = "vssadmin create shadow /for=C:"\nInvoke-Expression $command\n'}
[INFO] 2024-01-18 17:03:09,146 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 3, 9, 139424, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 3, 'team_name': 'team1', 'answer': b'# Specify the relative path to the executable within the AppData\\Local\\Temp folder\n#$executableRelativePath = "AppData\\Local\\Temp\\"\n\n# Build the full path using environment variables\n#$executableFolderPath = Join-Path $env:APPDATA $executableRelativePath\n$executableFolderPath = Join-Path $env:Temp\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\n# Iterate through each scheduled task and extract the executable path\nforeach ($task in $scheduledTasks) {\n    $taskInfo = Get-ScheduledTaskInfo -TaskName $task.TaskName -ErrorAction SilentlyContinue\n\n    if ($taskInfo -ne $null) {\n        $executablePath = $taskInfo.Actions.Execute -replace \'^.*?"(.*?\\.exe)".*$\', \'$1\'\n\n        if ($executablePath) {\n            Write-Host "Deleting task $($task.TaskName)..."\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n\n            # Construct the full path to the executable\n            $fullExecutablePath = Join-Path $executableFolderPath $executablePath\n\n            # Delete the executable file\n            if (Test-Path $fullExecutablePath) {\n                Write-Host "Deleting executable file $($fullExecutablePath)..."\n                Remove-Item -Path $fullExecutablePath -Force\n            }\n        }\n    }\n}\n\nWrite-Host "Task and file deletion completed."'}
