[INFO] 2024-01-18 16:51:16,147 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 51, 16, 132782, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Check the status of any antivirus product\r\n$antivirusStatus = Get-WmiObject -Namespace "root\\SecurityCenter2" -Class "AntivirusProduct"\r\n\r\n# Check if Windows Defender is running\r\n$defenderStatus = Get-MpPreference | Select-Object -ExpandProperty DisableRealtimeMonitoring\r\n\r\nif ($antivirusStatus -eq $null -or $defenderStatus -eq $true) {\r\n    Write-Host "Antivirus is disabled. Attempting to enable..."\r\n\r\n    # Attempt to enable Windows Defender\r\n    Start-Process "$psHome\\powershell.exe" -Verb Runas -ArgumentList \'-command "Set-MpPreference -DisableRealtimeMonitoring $false"\'\r\n    Write-Host "Windows Defender has been enabled."\r\n}\r\nelse {\r\n    Write-Host "Antivirus is active and running."\r\n}\r\n\r\n# Check the status of VSS\r\n$vssService = Get-Service -Name "VSS"\r\n\r\n# If VSS service is stopped or disabled, enable and start it\r\nif ($vssService.Status -ne \'Running\') {\r\n    Write-Host "VSS is not running. Attempting to start..."\r\n\r\n    # Set VSS startup type to automatic\r\n    Set-Service -Name "VSS" -StartupType Automatic\r\n\r\n    # Start the VSS service\r\n    Start-Service -Name "VSS"\r\n    Write-Host "VSS service has been started and set to automatic."\r\n}\r\nelse {\r\n    Write-Host "VSS is already running."\r\n}\r\n'}
[INFO] 2024-01-18 16:51:52,291 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 51, 52, 276425, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 5, 'team_name': 'team3', 'answer': b'# iterate all schedule tasks\n$scheduledTasks = Get-ScheduledTask\n\n# get user name and construct real back door path  into "C:\\Users\\<UserName>\\AppData\\Local\\Temp\\"\n$userName = $env:USERNAME\n$realBackDoorPath = "C:\\Users\\" + $userName + "\\AppData\\Local\\Temp\\"\n\n# iterate all schedule tasks\nforeach($task in $scheduledTasks)\n{\n    # get real path of task.Actions\n    $realPath = Resolve-Path $task.Actions\n    # if realPath starts with realBackDoorPath, then it is a back door, delete the task\n    if($realPath.StartsWith($realBackDoorPath))\n    {\n        Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n    }\n}'}
