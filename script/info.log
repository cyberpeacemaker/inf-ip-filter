[INFO] 2024-01-18 15:17:13,216 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 7, 17, 13, 202518, tzinfo=<UTC>), 'action_id': 18, 'action_name': 'YARA Rule for Miner', 'team_id': 4, 'team_name': 'team2', 'answer': b'rule MaliciousFile {\n    meta:\n        description = "Detects a file with SHA1 hash 524AB0A40594D2B5F620F542E87A45472979A416"\n    strings:\n        $sha1 = { 52 4A B0 A4 05 94 D2 B5 F6 20 F5 42 E8 7A 45 47 29 79 A4 16 }\n    condition:\n        $sha1 at 0\n}\n\n'}
