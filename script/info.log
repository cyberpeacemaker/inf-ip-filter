[INFO] 2024-01-18 17:34:10,633 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 34, 10, 625277, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 4, 'team_name': 'team2', 'answer': b'# PowerShell script to reset critical account passwords\n\n# Function to reset krbtgt password\nfunction Reset-KrbtgtPassword {\n    $krbtgt = Get-ADUser -Filter {SamAccountName -eq "krbtgt"}\n    for ($i = 0; $i -lt 2; $i++) {\n        # Generating a new random password\n        $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n        Set-ADAccountPassword -Identity $krbtgt -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force)\n        Start-Sleep -Seconds 10 # Wait for replication\n    }\n}\n\n# Function to reset passwords of Domain Controllers\nfunction Reset-DCPasswords {\n    $dcs = Get-ADComputer -Filter {OperatingSystem -Like "*Server*"}\n    foreach ($dc in $dcs) {\n        $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n        Set-ADAccountPassword -Identity $dc -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force)\n    }\n}\n\n# Function to reset passwords of Tier 0 group members, excluding \'hcr\' user\nfunction Reset-Tier0Passwords {\n    $tier0GroupMembers = Get-ADGroupMember -Identity "Tier0Group" | Where-Object { $_.SamAccountName -ne "hcr" }\n    foreach ($member in $tier0GroupMembers) {\n        $newPassword = [System.Web.Security.Membership]::GeneratePassword(20, 2)\n        Set-ADAccountPassword -Identity $member -NewPassword (ConvertTo-SecureString -AsPlainText $newPassword -Force)\n    }\n}\n\n# Execute password reset functions\nReset-KrbtgtPassword\nReset-DCPasswords\nReset-Tier0Passwords\n\nWrite-Host "Password reset process completed."\n'}
