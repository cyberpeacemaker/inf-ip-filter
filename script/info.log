[INFO] 2024-01-18 16:18:19,234 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 18, 19, 220058, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Check WinRAR Version\n$winrarPath = @("C:\\Program Files\\WinRAR\\WinRAR.exe", "C:\\Program Files (x86)\\WinRAR\\WinRAR.exe")\n$winrarVersionRequired = "6.23"\n$winrarVersion = $null\n\nforeach ($path in $winrarPath) {\n    if (Test-Path $path) {\n        $winrarVersion = [System.Diagnostics.FileVersionInfo]::GetVersionInfo($path).FileVersion\n        break\n    }\n}\n\nif ($winrarVersion -and ([version]$winrarVersion -lt [version]$winrarVersionRequired)) {\n    "WinRAR outdated" | Out-File -FilePath "C:\\Windows\\Temp\\checkresult.txt"\n} else {\n    "Checked" | Out-File -FilePath "C:\\Windows\\Temp\\checkresult.txt"\n}\n\n# Check and Enable Antivirus\n$defenderStatus = Get-MpPreference -ErrorAction SilentlyContinue\nif ($defenderStatus -and $defenderStatus.DisableRealtimeMonitoring -eq $true) {\n    Set-MpPreference -DisableRealtimeMonitoring $false\n}\n\n# Check VSS and Snapshot existence\n$vssService = Get-Service -Name \'VSS\'\nif ($vssService.Status -ne \'Running\') {\n    Start-Service -Name \'VSS\'\n}\n\n# Check for existing VSS snapshots\n$snapshots = Get-WmiObject -Class Win32_ShadowCopy\nif ($snapshots -eq $null) {\n    # Create a new VSS snapshot\n    # Note: Creating a snapshot requires administrative privileges\n    $volume = Get-WmiObject -Class Win32_Volume | Where-Object { $_.DriveType -eq 3 -and $_.DriveLetter -eq "C:" }\n    if ($volume) {\n        (Get-WmiObject -list win32_shadowcopy).Create($volume.Name, "ClientAccessible")\n    }\n}\n\n# Additional security checks and configurations can be added here\n'}
[INFO] 2024-01-18 16:19:12,096 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 8, 19, 12, 82154, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 6, 'team_name': 'team4', 'answer': b'# Check the status of any antivirus product\r\n$antivirusStatus = Get-WmiObject -Namespace "root\\SecurityCenter2" -Class "AntivirusProduct"\r\n\r\n# Check if Windows Defender is running\r\n$defenderStatus = Get-MpPreference | Select-Object -ExpandProperty DisableRealtimeMonitoring\r\n\r\nif ($antivirusStatus -eq $null -or $defenderStatus -eq $true) {\r\n    Write-Host "Antivirus is disabled. Attempting to enable..."\r\n\r\n    # Attempt to enable Windows Defender\r\n    Set-MpPreference -DisableRealtimeMonitoring $false\r\n    Write-Host "Windows Defender has been enabled."\r\n}\r\nelse {\r\n    Write-Host "Antivirus is active and running."\r\n}\r\n\r\n# Check the status of VSS\r\n$vssService = Get-Service -Name "VSS"\r\n\r\n# If VSS service is stopped or disabled, enable and start it\r\nif ($vssService.Status -ne \'Running\') {\r\n    Write-Host "VSS is not running. Attempting to start..."\r\n\r\n    # Set VSS startup type to automatic\r\n    Set-Service -Name "VSS" -StartupType Automatic\r\n\r\n    # Start the VSS service\r\n    Start-Service -Name "VSS"\r\n    Write-Host "VSS service has been started and set to automatic."\r\n}\r\nelse {\r\n    Write-Host "VSS is already running."\r\n}\r\n'}
