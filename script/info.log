[INFO] 2024-01-18 17:26:17,186 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 26, 17, 180010, tzinfo=<UTC>), 'action_id': 21, 'action_name': 'Reinforce Your Domain Against Stealthy Adversaries', 'team_id': 5, 'team_name': 'team3', 'answer': b'Function generateNewComplexPassword([int]$passwordNrChars) {\n\tProcess {\n\t\t$iterations = 0\n        Do {\n\t\t\tIf ($iterations -ge 20) {\n\t\t\t\tLogging "  --> Complex password generation failed after \'$iterations\' iterations..." "ERROR"\n\t\t\t\tLogging "" "ERROR"\n\t\t\t\tEXIT\n\t\t\t}\n\t\t\t$iterations++\n\t\t\t$pwdBytes = @()\n\t\t\t$rng = New-Object System.Security.Cryptography.RNGCryptoServiceProvider\n\t\t\tDo {\n\t\t\t\t[byte[]]$byte = [byte]1\n\t\t\t\t$rng.GetBytes($byte)\n\t\t\t\tIf ($byte[0] -lt 33 -or $byte[0] -gt 126) {\n\t\t\t\t\tCONTINUE\n\t\t\t\t}\n                $pwdBytes += $byte[0]\n\t\t\t}\n\t\t\tWhile ($pwdBytes.Count -lt $passwordNrChars)\n\t\t\t\t$pwd = ([char[]]$pwdBytes) -join \'\'\n\t\t\t} \n        Until (confirmPasswordIsComplex $pwd)\n        Return $pwd\n\t}\n}\n\n$krbtgtUsername = "krbtgt"\n$dcUsername = "administrator"\n$tier0Username = "jimmy"\n\n$passwordNrChars = 64\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $krbtgtUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $krbtgtUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $dcUsername -NewPassword $newPasswordSecure -Reset\n\n$newPassword = (generateNewComplexPassword $passwordNrChars).ToString()\n$newPasswordSecure = ConvertTo-SecureString $newPassword -AsPlainText -Force\nSet-ADAccountPassword -Identity $tier0Username -NewPassword $newPasswordSecure -Reset\n'}
