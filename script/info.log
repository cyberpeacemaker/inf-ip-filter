[INFO] 2024-01-18 14:16:24,309 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 6, 16, 24, 295290, tzinfo=<UTC>), 'action_id': 19, 'action_name': 'Firewall: Network Segments', 'team_id': 4, 'team_name': 'team2', 'answer': b'# Flush existing rules and set default policies\niptables -F\niptables -P INPUT DROP\niptables -P FORWARD DROP\niptables -P OUTPUT ACCEPT\n\n# Allow loopback traffic\niptables -A INPUT -i lo -j ACCEPT\niptables -A OUTPUT -o lo -j ACCEPT\n\n# Allow established and related connections\niptables -A INPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\niptables -A FORWARD -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\niptables -A OUTPUT -m conntrack --ctstate RELATED,ESTABLISHED -j ACCEPT\n\n# Allow SSH access to DMZ servers\niptables -A INPUT -p tcp --dport 22 -j ACCEPT\niptables -A FORWARD -p tcp --dport 22 -j ACCEPT\n\n# Allow HTTPS and SSH for Confluence server\niptables -A FORWARD -s 192.68.0.50 -p tcp -m multiport --sports 22,443 -j ACCEPT\n\n# Allow POP3, HTTPS, POP3S, and RDP for Exchange server\niptables -A FORWARD -s 192.68.0.25 -p tcp -m multiport --sports 110,443,995,3389 -j ACCEPT\n\n# Allow LDAP, SMB/CIFS, LDAPS, RDP, and HTTP for Zoho Server & AD\niptables -A FORWARD -d 192.68.1.100 -p tcp -m multiport --dports 389,445,636,3389,80 -j ACCEPT\n\n# Block communication between Confluence/Exchange and Intranet\niptables -A FORWARD -s 192.68.0.50 -d 192.68.1.0/24 -j DROP\niptables -A FORWARD -s 192.68.0.25 -d 192.68.1.0/24 -j DROP\n\n# Block DMZ zone from connecting to Zoho Server webpages\niptables -A FORWARD -s 192.68.0.0/24 -d 192.68.1.100 -p tcp --dport 80 -j DROP\n\n# Block management of DMZ from Intranet\niptables -A FORWARD -s 192.68.1.0/24 -d 192.68.0.0/24 -p tcp --dport 22 -j DROP\n\n'}
