[INFO] 2024-01-18 12:27:31,486 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 4, 27, 31, 465459, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 3, 'team_name': 'team1', 'answer': b'# Build the full path using environment variables\n$executablePath = $env:APPDATA\n\n# Get all scheduled tasks\n$scheduledTasks = Get-ScheduledTask\n\n# Iterate through each scheduled task and check if it contains the executable path\nforeach ($task in $scheduledTasks) {\n    $actions = $task.Actions\n    foreach ($action in $actions) {\n        if ($action.Arguments -like "$executablePath*") {\n            Write-Host "Deleting task $($task.TaskName)..."\n            Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n        }\n    }\n}\n\nWrite-Host "Task deletion completed."'}
