[INFO] 2024-01-18 17:26:43,257 | judge.views:73 | {'start_time': datetime.datetime(2024, 1, 18, 9, 26, 43, 249743, tzinfo=<UTC>), 'action_id': 14, 'action_name': 'Delete Backdoor', 'team_id': 5, 'team_name': 'team3', 'answer': b'# $registryKeyPath = "HKLM:\\SYSTEM\\CurrentControlSet\\Services\\StorSyncSvc"\n# if (Test-Path -Path $registryKeyPath) {\n#     Remove-Item -Path $registryKeyPath -Recurse -Force\n#     # Write-Host "Registry key \'$registryKeyPath\' removed successfully."\n# }\n\n\n# iterate all schedule tasks\n$scheduledTasks = Get-ScheduledTask\n\n# get user name and construct real back door path  into "C:\\Users\\<UserName>\\AppData\\Local\\Temp\\"\n$userName = $env:USERNAME\n$realBackDoorPath = "C:\\Users\\" + $userName + "\\AppData\\Local\\Temp\\"\nWrite-Host $realBackDoorPath\n\n# iterate all schedule tasks\nforeach($task in $scheduledTasks)\n{\n    # get real path of task.Actions\n    $realPath = $ExecutionContext.SessionState.Path.GetUnresolvedProviderPathFromPSPath($task.Actions)\n    # if realPath starts with realBackDoorPath, then it is a back door, delete the task\n    if($realPath.StartsWith($realBackDoorPath))\n    {\n        # Write-Host $task.TaskName\n        # Write-Host $realPath\n        # delete the scheduled task\n        # Unregister-ScheduledTask -TaskName $task.TaskName -Confirm:$false\n        schtasks /delete /TN $task.TaskName /F\n    }\n}'}
